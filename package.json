{
  "name": "@yemo-dev/yebail",
  "version": "4.2.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "WhatsApp Web API Library",
  "keywords": [
    "baileys",
    "yebail",
    "whatsapp",
    "whatsapp-web",
    "bot"
  ],
  "license": "MIT",
  "author": "yemo-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/yemo-dev/baileys.git"
  },
  "type": "commonjs",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib/*",
    "lib/Defaults/yebail-version.json",
    "WAProto/*",
    "Media/*",
    "scripts/*",
    "engine-requirements.js",
    "LICENSE"
  ],
  "scripts": {
    "build:all": "yarn build:types && typedoc",
    "build:docs": "typedoc",
    "build:tsc": "yarn build:types",
    "build:types": "tsc -p tsconfig.types.json",
    "changelog:last": "conventional-changelog -p angular -r 2",
    "changelog:preview": "conventional-changelog -p angular -u",
    "changelog:update": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "gen:protobuf": "sh WAProto/GenerateStatics.sh",
    "lint": "eslint src --ext .js,.ts,.jsx,.tsx",
    "lint:fix": "eslint src --fix --ext .js,.ts,.jsx,.tsx",
    "maintenance:on": "node -e \"const fs=require('fs'),p='lib/Defaults/index.js',c=fs.readFileSync(p,'utf8').replace(/exports\\.MAINTENANCE_MODE\\s*=\\s*(true|false)/,'exports.MAINTENANCE_MODE = true');fs.writeFileSync(p,c);console.log('[yebail] Maintenance mode ON')\"",
    "maintenance:off": "node -e \"const fs=require('fs'),p='lib/Defaults/index.js',c=fs.readFileSync(p,'utf8').replace(/exports\\.MAINTENANCE_MODE\\s*=\\s*(true|false)/,'exports.MAINTENANCE_MODE = false');fs.writeFileSync(p,c);console.log('[yebail] Maintenance mode OFF')\"",
    "preinstall": "node ./engine-requirements.js",
    "release": "release-it",
    "test": "jest --passWithNoTests",
    "update:version": "node scripts/update-wa-version.js"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "async-mutex": "^0.5.0",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "gradient-string": "^2.0.2",
    "cache-manager": "^5.7.6",
    "cheerio": "^1.0.0-rc.10",
    "libphonenumber-js": "^1.10.20",
    "lodash": "^4.17.21",
    "lru-cache": "^10.4.3",
    "music-metadata": "^11.12.3",
    "pino": "^9.6",
    "protobufjs": "^6.11.3",
    "uuid": "^10.0.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@adiwajshing/eslint-config": "github:adiwajshing/eslint-config",
    "@types/got": "^9.6.11",
    "@types/jest": "^27.5.1",
    "@types/node": "^16.18.126",
    "@types/sharp": "^0.29.4",
    "@types/ws": "^8.0.0",
    "conventional-changelog-cli": "^2.2.2",
    "eslint": "^8.0.0",
    "jest": "^27.0.6",
    "jimp": "^0.16.1 || ^0.22.0 || ^1.0.0",
    "json": "^11.0.0",
    "link-preview-js": "^3.0.0",
    "open": "^8.4.2",
    "qrcode-terminal": "^0.12.0",
    "release-it": "^15.10.3",
    "sharp": "^0.34.1",
    "ts-jest": "^27.0.3",
    "ts-node": "^10.8.1",
    "typedoc": "^0.27.9",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0",
    "audio-decode": "^2.1.3",
    "jimp": "^0.16.1 || ^0.22.0 || ^1.0.0",
    "link-preview-js": "^3.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.1"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "audio-decode": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    },
    "qrcode-terminal": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "packageManager": "yarn@1.22.19",
  "engines": {
    "node": ">=20.0.0"
  }
}
