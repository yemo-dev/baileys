{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./lib"
  },
  "include": [
    "lib/**/*.js",
    "WAProto/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
