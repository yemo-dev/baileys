{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "."
  },
  "include": [
    "lib/index.js"
  ],
  "exclude": [
    "node_modules",
    "lib/Signal/libsignal-node/src/**/*.js",
    "**/*.d.ts"
  ]
}
